{
  "schema_version": 1,
  "family": "toy_qwen3_asr",
  "display_name": "Toy Qwen3 ASR",
  "category": "asr",
  "status": "experimental",
  "tasks": ["asr"],
  "modes": ["offline"],
  "runtime": {
    "tags": ["server", "cuda", "vulkan", "cpu"],
    "default_format": "safetensors"
  },
  "capabilities": {
    "timestamps": true,
    "speaker_reference": false,
    "style_condition": false,
    "voice_design": false,
    "languages": ["auto", "en", "zh"]
  },
  "options": {
    "request": [
      {
        "name": "language",
        "type": "enum",
        "values": ["auto", "en", "zh"],
        "default": "auto",
        "description": "Recognition language."
      },
      {
        "name": "return_timestamps",
        "type": "bool",
        "default": false,
        "description": "Return token timestamps when supported."
      }
    ],
    "session": [
      {
        "name": "toy_qwen3_asr.lookahead",
        "type": "int",
        "default": 3,
        "description": "Toy decoder lookahead."
      }
    ],
    "load": [
      {
        "name": "toy_qwen3_asr.weight_type",
        "type": "enum",
        "values": ["native", "f32", "f16", "bf16", "q8_0"],
        "default": "native",
        "description": "Toy weight storage type."
      }
    ]
  },
  "packages": [
    {
      "id": "toy_qwen3_asr_local",
      "display_name": "Toy Qwen3 ASR Local Snapshot",
      "format": "safetensors",
      "precision": "native",
      "target_directory": "Toy-Qwen3-ASR",
      "required_files": ["config.json", "generation_config.json", "tokenizer_config.json", "model.safetensors"],
      "layout": "safetensors",
      "download": {
        "kind": "local_snapshot",
        "path": "../toy_package",
        "include": ["config.json", "generation_config.json", "tokenizer_config.json", "model.safetensors"]
      },
      "description": "Local toy package used by the model spec demo."
    },
    {
      "id": "toy_qwen3_asr_hf_snapshot",
      "display_name": "Toy Qwen3 ASR HF Snapshot",
      "format": "safetensors",
      "precision": "native",
      "target_directory": "Toy-Qwen3-ASR-HF",
      "required_files": ["config.json", "generation_config.json", "tokenizer_config.json", "model.safetensors"],
      "layout": "safetensors",
      "download": {
        "kind": "huggingface_snapshot",
        "repo": "audio-cpp/toy-qwen3-asr",
        "revision": "main",
        "include": ["config.json", "generation_config.json", "tokenizer_config.json", "model.safetensors"],
        "exclude": ["*.md", "*.png"],
        "gated": false
      },
      "description": "Fake direct Hugging Face snapshot package."
    },
    {
      "id": "toy_qwen3_asr_gguf_q8",
      "display_name": "Toy Qwen3 ASR GGUF Q8",
      "format": "gguf",
      "precision": "q8_0",
      "target_directory": "Toy-Qwen3-ASR-GGUF",
      "required_files": ["toy-qwen3-asr-q8_0.gguf"],
      "layout": "gguf",
      "download": {
        "kind": "huggingface_snapshot",
        "repo": "audio-cpp/audio.cpp-gguf",
        "revision": "main",
        "include": ["Toy-Qwen3-ASR-GGUF/toy-qwen3-asr-q8_0.gguf"],
        "strip_prefix": "Toy-Qwen3-ASR-GGUF",
        "gated": false
      },
      "description": "Fake standalone GGUF package with an embedded spec."
    },
    {
      "id": "toy_qwen3_asr_convert_q8",
      "display_name": "Toy Qwen3 ASR Convert to GGUF Q8",
      "format": "gguf",
      "precision": "q8_0",
      "target_directory": "Toy-Qwen3-ASR-GGUF-Q8",
      "required_files": ["toy-qwen3-asr-q8_0.gguf"],
      "layout": "gguf",
      "download": {
        "kind": "converter",
        "converter": "audiocpp_gguf",
        "description": "Download the safetensors package first, then convert it to q8_0 GGUF."
      },
      "description": "Fake generated package for converter-driven installs."
    },
    {
      "id": "toy_qwen3_asr_manual",
      "display_name": "Toy Qwen3 ASR Manual Package",
      "format": "safetensors",
      "precision": "native",
      "target_directory": "Toy-Qwen3-ASR-Manual",
      "required_files": ["config.json", "model.safetensors"],
      "layout": "safetensors",
      "download": {
        "kind": "unsupported",
        "reason": "Manual license approval is required before download."
      },
      "description": "Fake package that a downloader should list but not install automatically."
    }
  ],
  "layouts": {
    "safetensors": {
      "format": "safetensors",
      "roots": {
        "model": "."
      },
      "files": {
        "config": "model:config.json",
        "generation_config": "model:generation_config.json",
        "tokenizer_config": "model:tokenizer_config.json"
      },
      "optional_files": {
        "tokenizer_json": "model:tokenizer.json"
      },
      "tensors": {
        "weights": "model:model.safetensors"
      }
    },
    "gguf": {
      "format": "gguf",
      "roots": {
        "model": ".",
        "weights": "$gguf"
      },
      "files": {
        "config": "model:config.json"
      },
      "tensors": {
        "weights": "weights:"
      }
    }
  },
  "companions": [
    {
      "id": "toy_qwen3_forced_aligner",
      "kind": "model",
      "family": "qwen3_forced_aligner",
      "option": "toy_qwen3_asr.forced_aligner",
      "required": false,
      "required_for": ["timestamps"]
    },
    {
      "id": "toy_vad",
      "kind": "model",
      "family": "silero_vad",
      "option": "toy_qwen3_asr.vad",
      "required": false,
      "required_for": ["long_audio"]
    }
  ],
  "ui": {
    "recommended_package": "toy_qwen3_asr_local",
    "min_vram_gb": 1,
    "tags": ["ASR"],
    "docs": ["examples/model_spec_demo/README.md"],
    "summary": "Toy ASR package used to prove the model-spec subsystem shape."
  },
  "sources": [
    {
      "format": "safetensors",
      "roots": {
        "model": "."
      },
      "files": {
        "config": "model:config.json",
        "generation_config": "model:generation_config.json",
        "tokenizer_config": "model:tokenizer_config.json"
      },
      "optional_files": {
        "tokenizer_json": "model:tokenizer.json"
      },
      "tensors": {
        "weights": "model:model.safetensors"
      }
    }
  ]
}
